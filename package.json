{
  "name": "uk-curriculum-mcp",
  "version": "1.0.2",
  "description": "MCP server providing UK curriculum data — GCSE/A-Level specifications, paper structures, assessment objectives, and grade boundaries for AQA, Edexcel, OCR",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "uk-curriculum-mcp": "dist/src/index.js"
  },
  "files": [
    "dist/",
    "data/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "validate": "npx tsx scripts/validate-data.ts",
    "start": "node dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "uk-curriculum",
    "gcse",
    "a-level",
    "education",
    "aqa",
    "edexcel",
    "ocr",
    "exam",
    "specification",
    "grade-boundaries",
    "teaching",
    "ai-tools"
  ],
  "author": "Anas Abdi <anas@shortlistops.co.uk>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AnasInno/uk-curriculum-mcp"
  },
  "homepage": "https://github.com/AnasInno/uk-curriculum-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "vitest": "^4.1.2"
  }
}
